#!/usr/bin/env python3
import json
import pathlib
from datetime import date
import requests

BASE_DIR = pathlib.Path("/opt/research-automation")
CONFIG_FILE = BASE_DIR / "config" / ".env"
DATA_DIR = BASE_DIR / "data"


def load_env(env_path: pathlib.Path) -> dict:
    data = {}
    if not env_path.exists():
        raise FileNotFoundError(f".env not found: {env_path}")
    for line in env_path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        data[k.strip()] = v.strip()
    return data


def find_latest_papers_json(topic: str) -> pathlib.Path:
    topic_dir = DATA_DIR / topic
    if not topic_dir.exists():
        raise FileNotFoundError(f"Topic directory not found: {topic_dir}")
    candidates = sorted(topic_dir.glob("*/papers.json"))
    if not candidates:
        raise FileNotFoundError(f"No papers.json found under: {topic_dir}")
    return candidates[-1]


def extract_outputs(resp_json: dict) -> dict:
    if "data" in resp_json and isinstance(resp_json["data"], dict):
        return resp_json["data"].get("outputs", {}) or {}
    return resp_json.get("outputs", {}) or {}


def main():
    env = load_env(CONFIG_FILE)

    dify_base_url = env.get("DIFY_BASE_URL", "").rstrip("/")
    dify_api_key = env.get("DIFY_API_KEY", "").strip()
    dify_workflow_id = env.get("DIFY_WORKFLOW_ID", "").strip()
    topic = env.get("TOPIC", "未命名主題").strip()

    if not dify_base_url:
        raise ValueError("DIFY_BASE_URL is empty in .env")
    if not dify_api_key:
        raise ValueError("DIFY_API_KEY is empty in .env")
    if not dify_workflow_id:
        raise ValueError("DIFY_WORKFLOW_ID is empty in .env")

    papers_path = find_latest_papers_json(topic)
    papers_data = json.loads(papers_path.read_text(encoding="utf-8"))

    report_date = papers_data.get("report_date", date.today().isoformat())

    payload = {
        "inputs": {
            "topic": papers_data.get("topic", topic),
            "report_data": report_date,
            "papers_json": json.dumps(papers_data, ensure_ascii=False)
        },
        "response_mode": "blocking",
        "user": "allen-research-automation"
    }

    url = f"{dify_base_url}/workflows/{dify_workflow_id}/run"
    headers = {
        "Authorization": f"Bearer {dify_api_key}",
        "Content-Type": "application/json"
    }

    response = requests.post(url, headers=headers, json=payload, timeout=300)
    response.raise_for_status()
    result = response.json()

    run_dir = papers_path.parent

    (run_dir / "raw_dify_response.json").write_text(
        json.dumps(result, ensure_ascii=False, indent=2),
        encoding="utf-8"
    )

    outputs = extract_outputs(result)

    if outputs:
        (run_dir / "workflow_outputs.json").write_text(
            json.dumps(outputs, ensure_ascii=False, indent=2),
            encoding="utf-8"
        )

        result_text = outputs.get("result_text", "").strip()
        if result_text:
            (run_dir / "result_text.md").write_text(
                result_text,
                encoding="utf-8"
            )
            (run_dir / "report.md").write_text(
                result_text,
                encoding="utf-8"
            )

    print(f"papers_json: {papers_path}")
    print(f"raw_response: {run_dir / 'raw_dify_response.json'}")

    if outputs:
        print(f"outputs_json: {run_dir / 'workflow_outputs.json'}")
        if outputs.get("result_text"):
            print(f"result_text_md: {run_dir / 'result_text.md'}")
            print(f"report_md: {run_dir / 'report.md'}")


if __name__ == "__main__":
    main()
